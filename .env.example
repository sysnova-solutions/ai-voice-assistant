# APP_URL: The URL where this applet is hosted.
APP_URL="YOUR_APP_URL"

# Supabase Credentials for DB & Auth
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
# Service Role Key allows the server-side dashboard to safely bypass RLS policies
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Control seeding of demo data into the Supabase database on server startup
SEED_DEMO_DATA="false"

# ElevenLabs Voice/Text Agent Config
ELEVENLABS_AGENT_ID="your-elevenlabs-agent-id"
VITE_ELEVENLABS_AGENT_ID="your-elevenlabs-agent-id"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# n8n Webhook Endpoint for Notifications (Slack/Gmail) and database syncs
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/your-route"

# Dedicated welcome-email webhook. Point this to an n8n workflow that sends Gmail welcome emails.
WELCOME_EMAIL_WEBHOOK_URL="https://your-n8n-instance.com/webhook/customer-welcome-email"

# Owner Portal Credentials & Session Secret
OWNER_EMAIL="owner@sysnovasolutions.com"
OWNER_PASSWORD="your_secure_password"
OWNER_SESSION_SECRET="your_owner_session_secret"

# Optional: if omitted, customer sessions use OWNER_SESSION_SECRET.
CUSTOMER_SESSION_SECRET="your_customer_session_secret"
